# Polsia Fork — Environment Configuration

# ─── API ───────────────────────────────────────────────────────────────────
API_KEY=dev-key-change-in-production
DEBUG=true
LOG_LEVEL=INFO
ALLOWED_HOSTS=*

# ─── Database (Postgres for production, SQLite for local dev) ──────────────
DATABASE_URL=sqlite+aiosqlite:///./polsia.db
# DATABASE_URL=postgresql+asyncpg://polsia:password@localhost:5432/polsia

# ─── Redis / Celery ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── LLM API ────────────────────────────────────────────────────────────────
LLM_API_URL=https://api.deepseek.com/v1/chat/completions
LLM_API_KEY=sk-your-deepseek-api-key
LLM_MODEL=deepseek-chat
LLM_API_MOCK=true

# ─── ChromaDB ───────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma

# ─── Schedules ──────────────────────────────────────────────────────────────
MORNING_CYCLE_HOUR=6
EVENING_CYCLE_HOUR=18

# ─── Stripe / Billing ───────────────────────────────────────────────────────
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_YEARLY=

# ─── Rate Limiting ──────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
