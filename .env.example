# ─── Polsia Fork Production Configuration ───

# API Security
API_KEY=change-this-to-a-secure-key

# Database (SQLite for demo, PostgreSQL for production)
# DATABASE_URL=sqlite+aiosqlite:///./polsia.db
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/polsia

# Redis (optional — agents fall back to inline execution)
# REDIS_URL=redis://host:6379/0
# CELERY_BROKER_URL=redis://host:6379/1
# CELERY_RESULT_BACKEND=redis://host:6379/1

# LLM API (mock mode = no real LLM calls)
LLM_API_MOCK=true
# LLM_API_KEY=sk-your-key
# LLM_API_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat

# Claude CLI (mock mode = no real subprocess)
CLAUDE_CLI_MOCK=true

# Sandbox mode (prevents real external API calls)
SANDBOX_MODE=true

# Debug
DEBUG=true
