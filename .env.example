# Polsia Fork — Environment Configuration

# API
API_KEY=dev-key-change-in-production

# Database (Postgres for production, SQLite for local dev)
DATABASE_URL=postgresql+asyncpg://polsia:polsia_password@localhost:5432/polsia
# DATABASE_URL=sqlite+aiosqlite:///./polsia.db  # Uncomment for local dev

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# LLM API (replaces Claude Code CLI)
LLM_API_URL=https://api.deepseek.com/v1/chat/completions
LLM_API_KEY=sk-your-deepseek-api-key
LLM_MODEL=deepseek-chat

# Mock mode (set true for development/testing — no real LLM calls)
LLM_API_MOCK=true

# ChromaDB
CHROMA_PERSIST_DIR=./data/chroma
